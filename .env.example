# ══════════════════════════════════════════════
# ISYTASK — Variables de Entorno
# ══════════════════════════════════════════════
# Copia este archivo como:
#   packages/db/.env    (solo DATABASE_URL)
#   apps/web/.env.local (todas las variables)

# ── Base de Datos (Supabase PostgreSQL) ──
DATABASE_URL="postgresql://postgres:TU_PASSWORD@db.XXXXX.supabase.co:5432/postgres"

# ── NextAuth ──
NEXTAUTH_URL="https://tu-dominio.com"
NEXTAUTH_SECRET="genera-con: openssl rand -base64 32"

# ── Cron Jobs (seguridad) ──
# Secret para autenticar llamadas de cron externos
CRON_SECRET="genera-con: openssl rand -hex 16"

# ══════════════════════════════════════════════
# NOTA: Las siguientes configuraciones se gestionan
# desde el panel de admin (Configuracion) y se
# almacenan en la base de datos:
#
# - Resend API Key (email)
# - Claves VAPID (push notifications)
# - Twilio Account SID/Auth Token (WhatsApp)
# - Nombre, logo y horarios de la empresa
# - Zona horaria, formato de fecha, idioma
# ══════════════════════════════════════════════
