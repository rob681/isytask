# ══════════════════════════════════════════════
# ISYTASK — Variables de Entorno
# ══════════════════════════════════════════════
# Copia este archivo como .env en la raíz,
# en apps/web/.env y en packages/db/.env
# con los valores reales de producción.

# ── Base de Datos (Supabase PostgreSQL) ──
DATABASE_URL="postgresql://postgres:TU_PASSWORD@db.XXXXX.supabase.co:5432/postgres"

# ── NextAuth ──
NEXTAUTH_URL="https://tu-dominio.com"
NEXTAUTH_SECRET="genera-un-secret-seguro-con-openssl-rand-base64-32"

# ── Google Drive (adjuntos de tareas) ──
GOOGLE_SERVICE_ACCOUNT_KEY='{"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}'
GOOGLE_DRIVE_ROOT_FOLDER_ID="id-de-la-carpeta-raiz-en-drive"

# ── Email — Resend (notificaciones) ──
RESEND_API_KEY="re_xxxxxxxxxxxx"
EMAIL_FROM="Isytask <notificaciones@tu-dominio.com>"

# ── WhatsApp Business API (opcional) ──
WHATSAPP_PHONE_NUMBER_ID="tu-phone-number-id"
WHATSAPP_ACCESS_TOKEN="tu-access-token"

# ── Web Push (notificaciones push, opcional) ──
# Genera con: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_KEY="tu-vapid-public-key"
VAPID_PRIVATE_KEY="tu-vapid-private-key"
