# ══════════════════════════════════════════════
# ISYTASK — Variables de Entorno
# ══════════════════════════════════════════════
# Copia este archivo como:
#   packages/db/.env    (solo DATABASE_URL)
#   apps/web/.env.local (todas las variables)

# ── Base de Datos (Supabase PostgreSQL) ──
DATABASE_URL="postgresql://postgres:TU_PASSWORD@db.XXXXX.supabase.co:5432/postgres"

# ── NextAuth ──
NEXTAUTH_URL="https://tu-dominio.com"
NEXTAUTH_SECRET="genera-con: openssl rand -base64 32"

# ── Cron Jobs (seguridad) ──
# Secret para autenticar llamadas de cron externos
CRON_SECRET="genera-con: openssl rand -hex 16"

# ── Supabase Storage ──
# URL del proyecto Supabase (sin /rest/v1 ni /storage)
SUPABASE_URL="https://XXXXX.supabase.co"
# Service Role Key (Dashboard → Settings → API → service_role)
SUPABASE_SERVICE_ROLE_KEY="tu-service-role-key"

# ── Stripe SKU IDs (opcional — configurar al lanzar a paid) ──
# Cada par price=ID viene de Stripe Dashboard → Products → Pricing
# Si NO están configurados, los productos siguen funcionando con trial
# manual (ecosystem.activateIsyweb crea 14-day trial sin Stripe).
STRIPE_PRICE_ISYTASK_BASIC=""
STRIPE_PRICE_ISYTASK_PRO=""
STRIPE_PRICE_ISYTASK_ENTERPRISE=""
STRIPE_PRICE_ISYSOCIAL_BASIC=""
STRIPE_PRICE_ISYSOCIAL_PRO=""
STRIPE_PRICE_ISYSOCIAL_ENTERPRISE=""
STRIPE_PRICE_ISYWEB_BASIC=""
STRIPE_PRICE_ISYWEB_PRO=""
STRIPE_PRICE_ISYWEB_ENTERPRISE=""

# ══════════════════════════════════════════════
# NOTA: Las siguientes configuraciones se gestionan
# desde el panel de admin (Configuracion) y se
# almacenan en la base de datos:
#
# - Resend API Key (email)
# - Claves VAPID (push notifications)
# - Twilio Account SID/Auth Token (WhatsApp)
# - Nombre, logo y horarios de la empresa
# - Zona horaria, formato de fecha, idioma
# ══════════════════════════════════════════════
