{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "cd ../.. && pnpm --filter @isytask/db db:generate && pnpm --filter @isytask/web build",
  "installCommand": "pnpm install",
  "framework": "nextjs",
  "outputDirectory": ".next",
  "crons": [
    {
      "path": "/api/cron/recurring-tasks",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/pending-reminders",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/sla-alerts",
      "schedule": "0 7 * * *"
    }
  ]
}
