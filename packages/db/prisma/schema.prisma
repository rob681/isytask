generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
  output        = "../../../apps/web/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ──────────────────────────────────────────────
// ENUMS
// ──────────────────────────────────────────────

enum Role {
  SUPER_ADMIN
  ADMIN
  COLABORADOR
  CLIENTE
  SOPORTE
  FACTURACION
  VENTAS
  ANALISTA
}

enum TaskStatus {
  RECIBIDA
  EN_PROGRESO
  DUDA
  REVISION
  FINALIZADA
  CANCELADA
}

enum RecurrenceType {
  DAILY
  WEEKLY
  MONTHLY
}

enum TaskCategory {
  URGENTE
  NORMAL
  LARGO_PLAZO
}

enum TokenType {
  INVITATION
  PASSWORD_RESET
  MFA_SETUP
}

enum NotificationChannel {
  EMAIL
  WHATSAPP
  IN_APP
}

enum NotificationType {
  TAREA_RECIBIDA
  TAREA_EN_PROGRESO
  TAREA_DUDA
  TAREA_EN_REVISION
  TAREA_FINALIZADA
  TAREA_CANCELADA
  NUEVO_COMENTARIO
  CAMBIO_SOLICITADO
  TAREA_PENDIENTE_RECORDATORIO
  SLA_ALERTA
  // Cross-app (Isysocial integration)
  ISYSOCIAL_POST_RECHAZADO
  ISYSOCIAL_POST_APROBADO
  ISYSOCIAL_OAUTH_EXPIRADO
  ISYSOCIAL_CONTENIDO_PUBLICADO
}

enum CrossAppEventStatus {
  PENDING
  PROCESSING
  DONE
  FAILED
}

enum TaskAssignmentRole {
  PRIMARY
  HELPER
}

enum FieldType {
  TEXT
  TEXTAREA
  NUMBER
  SELECT
  MULTISELECT
  CHECKBOX
  COLOR_PICKER
  FILE
  DATE
  URL
}

enum Product {
  ISYTASK
  ISYSOCIAL
}

// ──────────────────────────────────────────────
// AGENCY (multi-tenant)
// ──────────────────────────────────────────────

model Agency {
  id            String    @id @default(cuid())
  name          String
  slug          String    @unique
  logoUrl       String?
  logoWhiteUrl  String?
  maxUsers      Int       @default(50)
  planTier      String    @default("basic")
  billingEmail  String?
  trialEndsAt   DateTime?
  isActive      Boolean   @default(true)
  hideBranding  Boolean   @default(false)
  customAppName String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Ecosystem: Stripe customer shared across products
  stripeCustomerId String? @unique

  users          User[]
  services       Service[]
  tasks          Task[]
  recurringTasks RecurringTask[]
  taskTemplates  TaskTemplate[]
  subscriptions  Subscription[]

  @@map("agencies")
}

// ──────────────────────────────────────────────
// SUBSCRIPTIONS (multi-product billing)
// ──────────────────────────────────────────────

model Subscription {
  id       String @id @default(cuid())
  agencyId String
  agency   Agency @relation(fields: [agencyId], references: [id], onDelete: Cascade)

  product  Product
  planTier String // "basic" | "pro" | "enterprise"

  // Stripe
  stripeSubscriptionId String? @unique
  stripePriceId        String?

  // Billing status
  status             String    @default("trial") // "active" | "past_due" | "canceled" | "trial"
  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?
  trialEndsAt        DateTime?
  canceledAt         DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([agencyId, product])
  @@index([agencyId])
  @@index([product])
  @@map("subscriptions")
}

// ──────────────────────────────────────────────
// CROSS-PRODUCT DISCOUNTS
// ──────────────────────────────────────────────

model CrossProductDiscount {
  id              String  @id @default(cuid())
  product1        Product
  product2        Product
  discountPercent Float   @default(10)
  isActive        Boolean @default(true)

  @@unique([product1, product2])
  @@map("cross_product_discounts")
}

// ──────────────────────────────────────────────
// USERS & AUTH
// ──────────────────────────────────────────────

model User {
  id           String  @id @default(cuid())
  email        String  @unique
  passwordHash String?
  name         String
  phone        String?
  avatarUrl    String?
  role         Role
  isActive     Boolean @default(true)

  // Account lockout — incremented on every failed login, reset on success
  loginAttempts Int       @default(0)
  lockedUntil   DateTime?

  // MFA / TOTP — optional for ADMIN and SUPER_ADMIN
  mfaEnabled Boolean @default(false)
  totpSecret String? // stored encrypted

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  agencyId String?
  agency   Agency? @relation(fields: [agencyId], references: [id])

  clientProfile         ClientProfile?
  colaboradorProfile    ColaboradorProfile?
  notifications         Notification[]
  pushSubscriptions     PushSubscription[]
  expoPushTokens        ExpoPushToken[]
  sentComments          TaskComment[]
  taskStatusChanges     TaskStatusLog[]
  createdRecurringTasks RecurringTask[]
  tokens                Token[]
  whatsappContact       WhatsAppContact?
  videoComments         VideoComment[]      @relation("VideoCommentAuthor")

  @@index([agencyId])
  @@map("users")
}

// ──────────────────────────────────────────────
// CLIENT PROFILE
// ──────────────────────────────────────────────

model ClientProfile {
  id                   String   @id @default(cuid())
  userId               String   @unique
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyName          String?
  logoUrl              String?
  planName             String   @default("Básico")
  planDescription      String?
  monthlyTaskLimit     Int      @default(10)
  revisionLimitPerTask Int      @default(3)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  tasks                Task[]
  assignedColaboradors ColaboradorClientAssignment[]
  allowedServices      ClientServiceAccess[]
  recurringTasks       RecurringTask[]
  whatsappContacts     WhatsAppContact[]
  responseMetrics      ClientResponseMetric[]

  @@map("client_profiles")
}

// ──────────────────────────────────────────────
// COLABORADOR PROFILE
// ──────────────────────────────────────────────

model ColaboradorProfile {
  id          String   @id @default(cuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  specialty   String?
  permissions Json     @default("[]")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  assignedTasks            Task[]
  taskAssignments          TaskAssignment[]
  assignedClients          ColaboradorClientAssignment[]
  recurringTasks           RecurringTask[]               @relation("RecurringTaskColaborador")
  recurringTaskAssignments RecurringTaskAssignment[]
  velocityMetrics          ColaboradorVelocityMetric[]

  @@map("colaborador_profiles")
}

// ──────────────────────────────────────────────
// COLABORADOR <-> CLIENT ASSIGNMENT
// ──────────────────────────────────────────────

model ColaboradorClientAssignment {
  id            String             @id @default(cuid())
  colaboradorId String
  colaborador   ColaboradorProfile @relation(fields: [colaboradorId], references: [id], onDelete: Cascade)
  clientId      String
  client        ClientProfile      @relation(fields: [clientId], references: [id], onDelete: Cascade)
  assignedAt    DateTime           @default(now())

  @@unique([colaboradorId, clientId])
  @@map("colaborador_client_assignments")
}

// ──────────────────────────────────────────────
// CLIENT <-> SERVICE ACCESS
// ──────────────────────────────────────────────

model ClientServiceAccess {
  id        String        @id @default(cuid())
  clientId  String
  client    ClientProfile @relation(fields: [clientId], references: [id], onDelete: Cascade)
  serviceId String
  service   Service       @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  createdAt DateTime      @default(now())

  @@unique([clientId, serviceId])
  @@map("client_service_access")
}

// ──────────────────────────────────────────────
// SERVICES & DYNAMIC FORM FIELDS
// ──────────────────────────────────────────────

model Service {
  id             String   @id @default(cuid())
  name           String
  description    String?
  estimatedHours Int
  slaHours       Int?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  agencyId String
  agency   Agency @relation(fields: [agencyId], references: [id])

  // AI Agent configuration
  agentEnabled      Boolean @default(false)
  agentInstructions String? @db.Text
  agentModel        String?

  formFields     ServiceFormField[]
  tasks          Task[]
  clientAccess   ClientServiceAccess[]
  recurringTasks RecurringTask[]
  templates      TaskTemplate[]

  @@unique([agencyId, name])
  @@index([agencyId])
  @@map("services")
}

model ServiceFormField {
  id          String         @id @default(cuid())
  serviceId   String
  service     Service        @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  fieldName   String
  label       String
  fieldType   FieldType
  placeholder String?
  isRequired  Boolean        @default(false)
  sortOrder   Int            @default(0)
  options     Json?
  validation  Json?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  responses   TaskResponse[]

  @@unique([serviceId, fieldName])
  @@map("service_form_fields")
}

// ──────────────────────────────────────────────
// TASKS
// ──────────────────────────────────────────────

model Task {
  id            String              @id @default(cuid())
  taskNumber    Int
  clientId      String
  client        ClientProfile       @relation(fields: [clientId], references: [id])
  serviceId     String
  service       Service             @relation(fields: [serviceId], references: [id])
  colaboradorId String?
  colaborador   ColaboradorProfile? @relation(fields: [colaboradorId], references: [id])

  agencyId String
  agency   Agency @relation(fields: [agencyId], references: [id])

  title       String
  description String?
  category    TaskCategory
  status      TaskStatus   @default(RECIBIDA)

  // Optional context provided at creation — feeds future agent memory
  // Surfaced via a "Agregar contexto" toggle, never required
  purpose String? @db.Text

  estimatedHours Int
  extraHours     Int       @default(0)
  startedAt      DateTime?
  completedAt    DateTime?
  dueAt          DateTime?

  // Outcome captured after task completion — feeds future agent memory
  // Set via a modal on transition to COMPLETED, all fields optional
  outcomeNote   String?   @db.Text // free-form, ~500 chars expected
  outcomeRating Int? // 1-5, user-reported satisfaction with how it went
  outcomeAt     DateTime? // when the outcome was recorded (may differ from completedAt)

  revisionsUsed  Int @default(0)
  revisionsLimit Int

  formData Json?

  // Cross-app: Isysocial integration (optional link to a Post)
  isysocialPostId   String? // ID of the linked Post in isysocial schema
  isysocialPostType String? // "IMAGE" | "CAROUSEL" | "STORY" | "REEL" | "VIDEO" | "TEXT"

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  comments         TaskComment[]
  statusLog        TaskStatusLog[]
  attachments      TaskAttachment[]
  assignments      TaskAssignment[]
  responses        TaskResponse[]
  whatsappMessages WhatsAppMessage[]
  riskAssessment   RiskAssessment?
  crossAppEvents   CrossAppEvent[]

  @@unique([agencyId, taskNumber])
  @@index([agencyId, status])
  @@index([clientId, status])
  @@index([colaboradorId, status])
  @@index([status, category])
  @@index([createdAt])
  @@index([isysocialPostId])
  @@map("tasks")
}

// ──────────────────────────────────────────────
// TASK RESPONSES (per-field answers)
// ──────────────────────────────────────────────

model TaskResponse {
  id        String           @id @default(cuid())
  taskId    String
  task      Task             @relation(fields: [taskId], references: [id], onDelete: Cascade)
  fieldId   String
  field     ServiceFormField @relation(fields: [fieldId], references: [id], onDelete: Cascade)
  fieldName String
  value     Json?
  skipped   Boolean          @default(false)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  @@unique([taskId, fieldId])
  @@index([taskId])
  @@map("task_responses")
}

// ──────────────────────────────────────────────
// TASK STATUS AUDIT LOG
// ──────────────────────────────────────────────

model TaskStatusLog {
  id          String      @id @default(cuid())
  taskId      String
  task        Task        @relation(fields: [taskId], references: [id], onDelete: Cascade)
  fromStatus  TaskStatus?
  toStatus    TaskStatus
  changedById String
  changedBy   User        @relation(fields: [changedById], references: [id])
  note        String?
  createdAt   DateTime    @default(now())

  @@index([taskId, createdAt])
  @@map("task_status_log")
}

// ──────────────────────────────────────────────
// COMMENTS
// ──────────────────────────────────────────────

model TaskComment {
  id         String   @id @default(cuid())
  taskId     String
  task       Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  authorId   String
  author     User     @relation(fields: [authorId], references: [id])
  content    String
  isQuestion Boolean  @default(false)
  isInternal Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([taskId, createdAt])
  @@map("task_comments")
}

model VideoComment {
  id              String   @id @default(cuid())
  mediaType       String // "POST_MEDIA" | "TASK_FILE"
  mediaId         String // Foreign key to PostMedia.id or Task.id
  authorId        String
  author          User     @relation("VideoCommentAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  content         String
  timecodeSeconds Float? // Timestamp in seconds (e.g., 15.5 for 15.5 seconds)
  isInternal      Boolean  @default(false)
  isResolved      Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([mediaId, timecodeSeconds])
  @@map("video_comments")
}

// ──────────────────────────────────────────────
// FILE ATTACHMENTS
// ──────────────────────────────────────────────

model TaskAttachment {
  id            String   @id @default(cuid())
  taskId        String
  task          Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  fileName      String
  fileSize      Int
  mimeType      String
  storagePath   String // Supabase Storage path: "bucket/folder/file"
  fileUrl       String // Public URL from Supabase Storage
  uploadedById  String
  isDeliverable Boolean  @default(false)
  createdAt     DateTime @default(now())

  @@index([taskId])
  @@map("task_attachments")
}

// ──────────────────────────────────────────────
// NOTIFICATIONS
// ──────────────────────────────────────────────

model Notification {
  id         String              @id @default(cuid())
  userId     String
  user       User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  agencyId   String?
  type       NotificationType
  channel    NotificationChannel
  title      String
  body       String
  taskId     String?
  isRead     Boolean             @default(false)
  sentAt     DateTime?
  failReason String?
  createdAt  DateTime            @default(now())

  @@index([userId, isRead, createdAt])
  @@index([agencyId, userId, isRead, createdAt])
  @@map("notifications")
}

// ──────────────────────────────────────────────
// SYSTEM CONFIGURATION
// ──────────────────────────────────────────────

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  @@index([userId])
  @@map("push_subscriptions")
}

model ExpoPushToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  platform  String   @default("ios") // "ios" | "android"
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@map("expo_push_tokens")
}

model SystemConfig {
  id    String @id @default(cuid())
  key   String @unique
  value Json

  @@map("system_config")
}

/// Platform-wide configuration managed only by SUPER_ADMIN.
/// Stores global Email, WhatsApp, AI, and platform settings.
model PlatformConfig {
  id    String @id @default(cuid())
  key   String @unique
  value Json

  @@map("platform_config")
}

// ──────────────────────────────────────────────
// RECURRING TASKS
// ──────────────────────────────────────────────

model RecurringTask {
  id            String              @id @default(cuid())
  clientId      String
  client        ClientProfile       @relation(fields: [clientId], references: [id], onDelete: Cascade)
  serviceId     String
  service       Service             @relation(fields: [serviceId], references: [id])
  title         String
  description   String?
  category      TaskCategory        @default(NORMAL)
  formData      Json?
  colaboradorId String?
  colaborador   ColaboradorProfile? @relation("RecurringTaskColaborador", fields: [colaboradorId], references: [id])

  agencyId String
  agency   Agency @relation(fields: [agencyId], references: [id])

  recurrenceType RecurrenceType
  recurrenceDay  Int? // 0-6 for weekly (0=Sunday), 1-31 for monthly
  recurrenceTime String         @default("09:00")

  isActive  Boolean   @default(true)
  lastRunAt DateTime?
  nextRunAt DateTime?

  createdById String
  createdBy   User     @relation(fields: [createdById], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Multi-assignment support — mirrors Task's pattern.
  // Helpers added here are pre-assigned when the cron creates the Task.
  assignments RecurringTaskAssignment[]

  @@index([agencyId, isActive])
  @@index([isActive, nextRunAt])
  @@map("recurring_tasks")
}

// ──────────────────────────────────────────────
// TASK TEMPLATES
// ──────────────────────────────────────────────

model TaskTemplate {
  id          String       @id @default(cuid())
  name        String
  description String?
  serviceId   String
  service     Service      @relation(fields: [serviceId], references: [id])
  category    TaskCategory @default(NORMAL)
  formData    Json?
  isActive    Boolean      @default(true)
  sortOrder   Int          @default(0)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  agencyId String
  agency   Agency @relation(fields: [agencyId], references: [id])

  @@index([agencyId])
  @@map("task_templates")
}

// ──────────────────────────────────────────────
// WHATSAPP INTEGRATION (Inbound messages → Task comments)
// ──────────────────────────────────────────────

enum WhatsAppMessageStatus {
  RECEIVED
  MATCHED
  COMMENT_CREATED
  UNMATCHED
  FAILED
}

model WhatsAppContact {
  id            String         @id @default(cuid())
  phone         String         @unique // E.164 format: +521234567890
  userId        String?        @unique
  user          User?          @relation(fields: [userId], references: [id], onDelete: SetNull)
  clientId      String?
  client        ClientProfile? @relation(fields: [clientId], references: [id], onDelete: SetNull)
  displayName   String?
  isVerified    Boolean        @default(false)
  isActive      Boolean        @default(true)
  lastMessageAt DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  messages WhatsAppMessage[]

  @@index([phone])
  @@index([userId])
  @@index([clientId])
  @@map("whatsapp_contacts")
}

model WhatsAppMessage {
  id        String          @id @default(cuid())
  contactId String
  contact   WhatsAppContact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  // Message provider IDs
  twilioSid     String? // Twilio message SID (null if from Meta)
  metaMessageId String? // Meta message ID (null if from Twilio)
  provider      String  @default("twilio") // "twilio" | "meta"

  direction String  @default("inbound") // "inbound" | "outbound"
  body      String  @db.Text
  mediaUrl  String?
  mediaType String?

  // Task matching
  status        WhatsAppMessageStatus @default(RECEIVED)
  matchedTaskId String?
  matchedTask   Task?                 @relation(fields: [matchedTaskId], references: [id], onDelete: SetNull)
  commentId     String? // The TaskComment created from this message
  aiConfidence  Float? // 0-1 confidence of the AI match
  aiReasoning   String? // Why the AI matched to this task

  createdAt DateTime @default(now())

  @@unique([twilioSid], name: "twilio_unique")
  @@unique([metaMessageId], name: "meta_unique")
  @@index([contactId, createdAt])
  @@index([status])
  @@index([matchedTaskId])
  @@index([provider])
  @@map("whatsapp_messages")
}

// ──────────────────────────────────────────────
// AUTH TOKENS (Invitations & Password Reset)
// ──────────────────────────────────────────────

model Token {
  id        String    @id @default(cuid())
  token     String    @unique
  type      TokenType
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([token, type])
  @@index([userId])
  @@map("tokens")
}

// ──────────────────────────────────────────────
// TASK ASSIGNMENTS (multi-assignment)
// ──────────────────────────────────────────────

model TaskAssignment {
  id            String             @id @default(cuid())
  taskId        String
  task          Task               @relation(fields: [taskId], references: [id], onDelete: Cascade)
  colaboradorId String
  colaborador   ColaboradorProfile @relation(fields: [colaboradorId], references: [id], onDelete: Cascade)
  role          TaskAssignmentRole @default(HELPER)
  assignedAt    DateTime           @default(now())
  assignedById  String?

  @@unique([taskId, colaboradorId])
  @@index([colaboradorId])
  @@map("task_assignments")
}

// ─── RECURRING TASK ASSIGNMENTS ──────────────────────────────────────────────
model RecurringTaskAssignment {
  id               String             @id @default(cuid())
  recurringTaskId  String
  recurringTask    RecurringTask      @relation(fields: [recurringTaskId], references: [id], onDelete: Cascade)
  colaboradorId    String
  colaborador      ColaboradorProfile @relation(fields: [colaboradorId], references: [id])
  role             String             @default("HELPER") // "PRIMARY" | "HELPER"
  createdAt        DateTime           @default(now())

  @@unique([recurringTaskId, colaboradorId])
  @@map("recurring_task_assignments")
}

// ──────────────────────────────────────────────
// RISK PREDICTION (AI-powered project health)
// ──────────────────────────────────────────────

enum RiskLevel {
  GREEN
  YELLOW
  RED
}

model RiskAssessment {
  id       String @id @default(cuid())
  taskId   String @unique
  task     Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)
  agencyId String

  // Risk factors (computed)
  riskScore                   Float // 0-100
  riskLevel                   RiskLevel @default(GREEN)
  daysUntilDeadline           Int?
  daysSinceLastClientResponse Int?
  daysSinceLastUpdate         Int
  assigneeActiveTaskCount     Int?
  clientAvgApprovalDays       Float? // historical: how long this client takes to approve
  teamAvgCompletionDays       Float? // historical: how long this team member takes

  // AI-generated insights
  prediction      String  @db.Text // Natural language prediction
  suggestedAction String? @db.Text // What to do about it

  analyzedAt DateTime @default(now())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([agencyId, riskLevel])
  @@index([riskLevel])
  @@map("risk_assessments")
}

model ClientResponseMetric {
  id       String        @id @default(cuid())
  clientId String
  client   ClientProfile @relation(fields: [clientId], references: [id], onDelete: Cascade)
  agencyId String

  avgApprovalDays     Float // average days to approve/respond
  avgResponseDays     Float // average days between comments
  tasksAnalyzed       Int // how many tasks were used to calculate
  slowestApprovalDays Float? // worst case

  month Int
  year  Int

  updatedAt DateTime @updatedAt

  @@unique([clientId, month, year])
  @@index([agencyId])
  @@map("client_response_metrics")
}

model ColaboradorVelocityMetric {
  id            String             @id @default(cuid())
  colaboradorId String
  colaborador   ColaboradorProfile @relation(fields: [colaboradorId], references: [id], onDelete: Cascade)
  agencyId      String

  avgCompletionDays Float // average days to complete a task
  tasksCompleted    Int
  onTimeRate        Float // % of tasks completed before deadline

  month Int
  year  Int

  updatedAt DateTime @updatedAt

  @@unique([colaboradorId, month, year])
  @@index([agencyId])
  @@map("colaborador_velocity_metrics")
}

// ──────────────────────────────────────────────
// CROSS-APP EVENTS (Isytask ↔ Isysocial sync)
// ──────────────────────────────────────────────

model CrossAppEvent {
  id        String              @id @default(cuid())
  sourceApp Product // ISYTASK | ISYSOCIAL
  targetApp Product
  eventType String // e.g. "POST_REJECTED", "TASK_FINALIZADA", "OAUTH_EXPIRED"
  agencyId  String
  status    CrossAppEventStatus @default(PENDING)

  // Optional references for traceability
  taskId          String?
  task            Task?   @relation(fields: [taskId], references: [id], onDelete: SetNull)
  isysocialPostId String? // Post ID in isysocial schema (no FK — cross-schema)

  // Event payload (flexible JSON for any event-specific data)
  payload Json @default("{}")

  // Processing
  errorMessage String?
  processedAt  DateTime?
  retryCount   Int       @default(0)

  createdAt DateTime @default(now())

  @@index([status, createdAt])
  @@index([agencyId, eventType])
  @@index([taskId])
  @@index([isysocialPostId])
  @@map("cross_app_events")
}

// ──────────────────────────────────────────────
// AUDIT LOG
// ──────────────────────────────────────────────

model AuditLog {
  id         String   @id @default(cuid())
  agencyId   String?
  userId     String? // null = system action
  action     String // USER_LOGIN, TASK_STATUS_CHANGED, USER_DELETED, etc.
  entityType String? // Task, User, Service, etc.
  entityId   String? // PK of the affected record
  oldValue   Json? // state before (for updates)
  newValue   Json? // state after
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  @@index([agencyId])
  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}
